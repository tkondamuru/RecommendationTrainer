## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is for a standard .NET project.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache and settings
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on separate drives
$RECYCLE.BIN/

# VS Code
.vscode/

# Custom for this project
DataExtractor/

# Large Data and Model files
recommendation_model_CA.zip
recommendation_model_US.zip
recommendation_training_CA.csv
recommendation_training_US.csv

# Secrets and local settings
[Pp]roperties/[Ll]aunch[Ss]ettings.json
